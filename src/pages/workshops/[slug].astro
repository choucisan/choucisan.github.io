---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const workshopItems = (await getCollection('workshops')).filter((item) => !item.data.draft);
  return workshopItems.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const isCvpr2026Intro = item.id === 'cvpr2026intro';
const isGaokaoCompass = item.id === 'gaokao_compass';
const date = item.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---
<BaseLayout title={`${item.data.title} | Workshops`} description={item.data.description} image={item.data.image} headerMode="glass" bodyClass={isCvpr2026Intro ? 'archive-body cvpr-explorer-body' : isGaokaoCompass ? 'archive-body gaokao-compass-body' : ''}>
  {isCvpr2026Intro ? (
    <main class="cvpr-explorer-page">
      <section class="cvpr-explorer-hero">
        <img class="publication-cloud publication-cloud-left" src="/assets/hero/cloud-large.png" alt="" aria-hidden="true" />
        <img class="publication-cloud publication-cloud-right" src="/assets/hero/cloud-large.png" alt="" aria-hidden="true" />
        <div class="container cvpr-explorer-hero-inner">
          <a class="detail-back" href="/workshops/">← Workshops</a>
          <h1>CVPR 2026 Paper Explorer</h1>
          <p class="cvpr-explorer-lede" data-i18n="heroText">Search, classify, and read bilingual structured summaries for CVPR 2026 papers.</p>
          <div class="cvpr-explorer-toolbar">
            <span class="cvpr-paper-count" data-paper-count>Loading papers...</span>
            <span class="cvpr-resource-link cvpr-resource-note">Summarized by MiMo-V2.5-Pro</span>
            <a class="cvpr-resource-link" href="https://huggingface.co/datasets/choucsan/CVPR_Papers" target="_blank" rel="noreferrer">Hugging Face</a>
            <a class="cvpr-resource-link" href="https://openaccess.thecvf.com/CVPR2026" target="_blank" rel="noreferrer">Source Data</a>
            <div class="cvpr-lang-switch" role="group" aria-label="Language">
              <button class="cvpr-lang-button is-active" type="button" data-lang="en">EN</button>
              <button class="cvpr-lang-button" type="button" data-lang="zh">中文</button>
            </div>
            <span class="cvpr-resource-link cvpr-view-counter" data-page-views data-page-views-label="View" data-page-views-path="/collections/cvpr2026intro/" hidden>View —</span>
          </div>
        </div>
      </section>

      <section class="cvpr-explorer-shell" id="cvpr-paper-explorer">
        <div class="cvpr-control-bar">
          <label class="cvpr-paper-search" for="cvpr-paper-search">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M10.8 18.1a7.3 7.3 0 1 1 0-14.6 7.3 7.3 0 0 1 0 14.6Zm5.2-2.1 4.5 4.5" />
            </svg>
            <input id="cvpr-paper-search" type="search" autocomplete="off" data-search />
          </label>
          <div class="cvpr-category-dropdown">
            <button class="cvpr-category-toggle" type="button" data-category-toggle>
              <span data-category-toggle-label>Categories</span>
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="m7 10 5 5 5-5" />
              </svg>
            </button>
            <div class="cvpr-category-popover" data-category-popover hidden>
              <div class="cvpr-category-column">
                <div class="cvpr-category-heading">
                  <span data-i18n="categories">Categories</span>
                  <button type="button" data-reset-filter>All</button>
                </div>
                <div class="cvpr-primary-list" data-primary-list></div>
              </div>
            </div>
          </div>
        </div>
        <section class="cvpr-paper-results" aria-live="polite">
          <div class="cvpr-results-head">
            <p data-result-summary>Loading...</p>
            <div class="cvpr-active-filter" data-active-filter></div>
          </div>
          <div class="cvpr-paper-grid" data-paper-grid></div>
          <p class="empty-results" data-empty-state hidden>No matching papers.</p>
        </section>
      </section>
    </main>
    <script src="/assets/cvpr2026/app.js" defer></script>
  ) : isGaokaoCompass ? (
    <main class="gaokao-compass-page">
      <section class="gaokao-compass-hero">
        <img class="publication-cloud publication-cloud-left" src="/assets/hero/cloud-large.png" alt="" aria-hidden="true" />
        <img class="publication-cloud publication-cloud-right" src="/assets/hero/cloud-large.png" alt="" aria-hidden="true" />
        <div class="container gaokao-compass-hero-inner">
          <a class="detail-back" href="/workshops/">← Workshops</a>
          <h1>2025年高考录取数据查询</h1>
          <p class="gaokao-compass-lede">连接分数、位次、招生计划与录取线，帮助家长和考生更快看清志愿选择空间。</p>
        </div>
      </section>

      <section class="gaokao-compass-shell" aria-live="polite">
        <div class="gaokao-control-bar">
          <label class="gaokao-select-wrap" for="gaokao-province">
            <span>省份</span>
            <select id="gaokao-province" data-gaokao-province></select>
          </label>
          <label class="gaokao-select-wrap" for="gaokao-category">
            <span>类别</span>
            <select id="gaokao-category" data-gaokao-category></select>
          </label>
          <label class="gaokao-select-wrap" for="gaokao-batch">
            <span>批次</span>
            <select id="gaokao-batch" data-gaokao-batch></select>
          </label>
          <label class="gaokao-search" for="gaokao-search">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M10.8 18.1a7.3 7.3 0 1 1 0-14.6 7.3 7.3 0 0 1 0 14.6Zm5.2-2.1 4.5 4.5" />
            </svg>
            <input id="gaokao-search" type="search" autocomplete="off" placeholder="输入学校、专业或分数，例如：浙江大学 / 临床医学 / 620" data-gaokao-search />
          </label>
          <button class="gaokao-query-button" type="button" data-gaokao-query>查询</button>
        </div>

        <div class="gaokao-status-strip">
          <span data-gaokao-status>正在加载 2025 高考数据索引...</span>
          <span data-gaokao-rank></span>
        </div>

        <section class="gaokao-results-panel">
          <div class="gaokao-results-head">
            <div>
              <p class="gaokao-kicker">查询结果</p>
              <h2 data-gaokao-results-title>先选择省份、类别和批次，再输入学校、专业或分数</h2>
            </div>
            <p data-gaokao-results-count>等待查询</p>
          </div>
          <div class="gaokao-results-grid" data-gaokao-results></div>
          <p class="empty-results" data-gaokao-empty hidden>没有找到匹配结果，可以放宽批次或换一个关键词。</p>
        </section>
        <section class="gaokao-insight-grid" data-gaokao-insights></section>
        <section class="gaokao-analysis-panel" data-gaokao-panel hidden></section>
      </section>
    </main>
    <script src="/assets/gaokao2025/app.js?v=20260627-2" defer></script>
  ) : (
    <main class="collection-detail">
      <section class="detail-hero">
        <div class="container detail-hero-stack">
          <a class="detail-back" href="/workshops/">← Workshops</a>
          <p class="detail-kicker-pill">{item.data.platform}</p>
          <h1>{item.data.title}</h1>
          <p class="detail-description">{item.data.description}</p>
          <div class="detail-meta">
            <span>{date}</span>
            {item.data.tags.map((tag) => <span>{tag}</span>)}
            {item.data.githubUrl && <a class="detail-meta-link is-github" href={item.data.githubUrl} target="_blank" rel="noreferrer">GitHub</a>}
            {item.data.huggingfaceUrl && <a class="detail-meta-link is-huggingface" href={item.data.huggingfaceUrl} target="_blank" rel="noreferrer">Hugging Face</a>}
            {item.data.bilibiliUrl && <a class="detail-meta-link is-bilibili" href={item.data.bilibiliUrl} target="_blank" rel="noreferrer">Bilibili</a>}
            <span class="detail-view-counter" data-page-views hidden>views —</span>
          </div>
          <div class="detail-cover detail-cover-wide">
            <img src={item.data.image} alt="" />
          </div>
        </div>
      </section>
      <article class="prose detail-page">
        <Content />
      </article>
    </main>
  )}
</BaseLayout>
